diff --git a/backup.js b/backup.js
new file mode 100644
--- /dev/null
+++ b/backup.js
@@ -0,0 +1,18 @@
+const { exec } = require("child_process");
+
+// Create a compressed backup of a user's project folder.
+// `projectName` comes from the API request body.
+function backupProject(projectName, callback) {
+  const dir = `/data/projects/${projectName}`;
+  const out = `/backups/${projectName}.tar.gz`;
+
+  // Looks fine: tar the directory into the backups folder.
+  exec(`tar -czf ${out} ${dir}`, (err) => {
+    if (err) return callback(err);
+    callback(null, out);
+  });
+}
+
+module.exports = { backupProject };
