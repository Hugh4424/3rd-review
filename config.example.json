{
  "version": 4,
  "runtime": {
    "root": "/tmp/3rd-review",
    "ttl_hours": 24,
    "max_prompt_bytes": 524288,
    "max_output_bytes": 10485760,
    "max_attachment_bytes": 10485760,
    "liveness_interval_ms": 1000,
    "max_wall_clock_ms": null,
    "orphan_timeout_ms": 30000
  },
  "attachment_roots": [
    { "root": "/absolute/path/to/approved-packets", "sources": ["skills", "review"] }
  ],
  "tiers": [["claude-code", "kimi", "codex", "opencode"]],
  "providers": {
    "claude-code": { "enabled": true, "command": "/absolute/path/to/claude", "model": null, "effort": "medium", "thinking": null, "auth": { "type": "native" }, "env": [] },
    "kimi": { "enabled": true, "command": "/absolute/path/to/kimi", "model": null, "effort": null, "thinking": true, "auth": { "type": "native" }, "env": [] },
    "codex": { "enabled": true, "command": "/absolute/path/to/codex", "model": null, "effort": "medium", "thinking": null, "auth": { "type": "native" }, "env": [] },
    "opencode": { "enabled": true, "command": "/absolute/path/to/opencode", "model": null, "effort": null, "thinking": null, "auth": { "type": "native" }, "env": [] }
  }
}
